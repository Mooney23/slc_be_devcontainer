{
  "name": "{{IMAGE-NAME-FOR-THE-SERVICE}}",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // The container needs NET_ADMIN and NET_RAW capabilities to configure
  // iptables. Without these, the firewall script cannot run.
  // This is safe because the firewall RESTRICTS access — these
  // capabilities are used to lock things DOWN, not open them up.
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],

  // Ensure Neovim config dirs exist on the host before mounting
  "initializeCommand": "mkdir -p ~/.config/nvim ~/.local/share/nvim && mkdir -p ~/.cache/.claude-skills-resolved && cp -rL ~/.claude/skills/* ~/.cache/.claude-skills-resolved/ 2>/dev/null || true && touch ~/.cache/.claude-user-CLAUDE.md && cp -L ~/.claude/CLAUDE.md ~/.cache/.claude-user-CLAUDE.md 2>/dev/null || true",

  "mounts": [
    // Neovim config
    "source=${localEnv:HOME}/.config/nvim,target=/home/dev/.config/nvim,type=bind,consistency=cached",

    // Neovim plugin/state data
    "source=${localEnv:HOME}/.local/share/nvim,target=/home/dev/.local/share/nvim,type=bind,consistency=cached",

    // Claude Code auth token (persists across container rebuilds)
    "source=${localEnv:HOME}/.claude,target=/home/dev/.claude,type=bind,consistency=cached",

    // Claude Code user config file (lives at ~/.claude.json, not inside ~/.claude/)
    "source=${localEnv:HOME}/.claude.json,target=/home/dev/.claude.json,type=bind,consistency=cached",

    // Host user-scope skills (flattened by initializeCommand), mounted
    // read-only as a STAGING dir. dev-post-start.sh copies these into the
    // real skills dir below.
    "source=${localEnv:HOME}/.cache/.claude-skills-resolved,target=/home/dev/.claude/skills-host,type=bind,readonly",
    "source=${localEnv:HOME}/.cache/.claude-user-CLAUDE.md,target=/home/dev/.claude/CLAUDE.md,type=bind,readonly",

    // The real skills dir: a tmpfs so the startup merge is writable and
    // ephemeral, and is never written back to the host's ~/.claude/skills.
    "target=/home/dev/.claude/skills,type=tmpfs",

    // pip cache so installs are fast across rebuilds
    "source=pip-cache,target=/home/dev/.cache/pip,type=volume",

    // EC2 SSH key for database tunnel (read-only, single key only)
    // Set EC2_KEY_PATH in your host environment to the full path of your key
    // e.g. export EC2_KEY_PATH=/path/to/your/key/file.pem
    "source=${localEnv:EC2_KEY_PATH},target=/home/dev/.ssh/ec2-key,type=bind,readonly",

    "source=${localEnv:NOTES_PATH},target=/workspace/notes,type=bind"

    // Browser automation auth (only if you enabled INSTALL_BROWSER):
    // a Playwright storage-state JSON (cookies + localStorage tokens) you
    // captured on the HOST after logging into the target app. Mounted
    // read-only so the headless browser starts pre-authenticated and never
    // writes the session back. Point the MCP server at it with
    // --storage-state (see .mcp.json and the README). Set BROWSER_AUTH_STATE
    // on your host to the file path.
    // ,"source=${localEnv:BROWSER_AUTH_STATE},target=/home/dev/.config/playwright-auth/storage-state.json,type=bind,readonly"

    // NOT MOUNTED (by design):
    //   ~/.ssh (full dir), ~/.aws, ~/.config/gcloud, ~/.kube, ~/.gnupg, ~/.netrc
    //
    // Git is done from the host, so no SSH agent forwarding either.
  ],

  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "EC2_PRIVATE_KEY_PATH": "/home/dev/.ssh/ec2-key",
    "DEV_EC2_HOST": "${localEnv:DEV_EC2_HOST}",
    "CLAUDE_CONFIG_DIR": "/home/dev/.claude",
    "HOST_HOME": "${localEnv:HOME}",
    "BITBUCKET_EMAIL": "${localEnv:BITBUCKET_EMAIL}",
    "BITBUCKET_TOKEN": "${localEnv:BITBUCKET_TOKEN}"
  },

  // Initialize the firewall on every container start.
  // This must run as root (via sudo), but the sudoers file only
  // allows this one specific script.
  "postStartCommand": "bash .devcontainer/post-start.sh",

  // Install Python deps on first creation
  "postCreateCommand": "pip install -r requirements/local.txt",

  "forwardPorts": [8000, 5432, 6379, 5000],

  "remoteUser": "dev",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "dev",
      "userUid": "1000",
      "userGid": "1000"
    }
  }
}
